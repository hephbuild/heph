# Every provider/driver is a `plugin`. A `builtin:` selects a compiled-in plugin
# by name; `path:`/`url:` points at a `*-plugin.json` manifest for a loadable
# cdylib (loaded in-process behind the stable ABI — native speed, no IPC). Each
# entry's `options:` map is passed to the plugin's construction.
plugins:
  - builtin: buildfile
    options:
      patterns:
        - BUILD
  - builtin: exec
  - builtin: bash
  - builtin: sh
  # The go plugin: one manifest names the cdylib for this host. The provider + its
  # go_* drivers all come from that one library. Installed to the user-global
  # ~/.heph by the `gen-example` script (which runs `install-go-plugin`).
  - path: ~/.heph/plugins/go/heph-go-plugin.json
    options:
      # Required. A pinned version → hermetic SDK download (reads nothing from
      # the host); or "host" → use the host `go` from PATH.
      gotool: "1.26.4"
      # SDK tarball SHA-256s, keyed "<version>/<goos>/<goarch>". Optional: an
      # absent host-platform entry downloads the SDK unverified (logged warning);
      # supply one to enforce verification (no built-in table — keeps the binary
      # free of release-specific data). Add a version by adding its rows here
      # (sha256 from https://go.dev/dl/?mode=json). Unused for gotool: "host".
      checksums:
        "1.26.4/linux/amd64": "1153d3d50e0ac764b447adfe05c2bcf08e889d42a02e0fe0259bd47f6733ad7f"
        "1.26.4/linux/arm64": "ef758ae7c6cf9267c9c0ef080b8965f453d89ab2d25d9eb22de4405925238768"
        "1.26.4/darwin/amd64": "05dc9b5f9997744520aaebb3d5deaa7c755371aebbfb7f97c2511a9f3367538d"
        "1.26.4/darwin/arm64": "b62ad2b6d7d2464f12a5bcad7ff47f19d08325773b5efd21610e445a05a9bf53"
# Sandbox FUSE overlay. `enabled: true | false | auto` — when on, inputs are
# served from an in-memory union filesystem instead of being copied into each
# sandbox (faster for large dep sets). `auto` uses FUSE only past an input-size
# threshold. On macOS, `backend` picks the userspace backend: `kext` (default;
# fastest, needs the macFUSE system extension approved) or `fskit` (Apple FSKit,
# macOS 15.4+; unprivileged — no kext — but mounts under /Volumes and needs the
# macFUSE FSKit file-system extension enabled). Ignored on Linux.
#fuse:
#  enabled: true
#  backend: kext
# Remote (shared) caches. Each entry is keyed by a name and has a `uri` plus
# `read`/`write` flags (both default true) and a `concurrency` request cap
# (default 10). Supported schemes: s3://, gs://, az://, http(s):// (credentials
# from the environment) and file:// / memory:// for local use. Blobs are
# gzip-compressed and streamed (never held whole in memory). Writes fan out to
# every writable cache in parallel (on a background task — the CLI stays open
# until the upload drains); reads try caches in measured-latency order and pull
# a whole revision from the first that has it. Measure/refresh the order with
# `heph tool cache measure-latency`.
#caches:
#  shared:
#    uri: s3://my-bucket/heph-cache
#    read: true
#    write: true
#    concurrency: 10
