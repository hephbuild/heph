# Every provider/driver is a `plugin`. A `builtin:` selects a compiled-in plugin
# by name; `path:`/`url:` points at a `*-plugin.json` manifest for a loadable
# cdylib (loaded in-process behind the stable ABI — native speed, no IPC). Each
# entry's `options:` map is passed to the plugin's construction.
plugins:
  - builtin: buildfile
    options:
      patterns:
        - BUILD
  - builtin: exec
  - builtin: bash
  - builtin: sh
  # The go plugin: one manifest names the cdylib for this host. The provider + its
  # go_* drivers all come from that one library. Installed to the user-global
  # ~/.heph by the `gen-example` script (which runs `install-go-plugin`).
  - path: ~/.heph/plugins/go/heph-go-plugin.json
    options:
      # Required. A pinned version → hermetic SDK download (reads nothing from
      # the host); or "host" → use the host `go` from PATH.
      gotool: "1.26.4"
#fuse:
#  enabled: true
# Remote (shared) caches. Each entry is keyed by a name and has a `uri` plus
# `read`/`write` flags (both default true) and a `concurrency` request cap
# (default 10). Supported schemes: s3://, gs://, az://, http(s):// (credentials
# from the environment) and file:// / memory:// for local use. Blobs are
# gzip-compressed and streamed (never held whole in memory). Writes fan out to
# every writable cache in parallel (on a background task — the CLI stays open
# until the upload drains); reads try caches in measured-latency order and pull
# a whole revision from the first that has it. Measure/refresh the order with
# `heph tool cache measure-latency`.
#caches:
#  shared:
#    uri: s3://my-bucket/heph-cache
#    read: true
#    write: true
#    concurrency: 10
