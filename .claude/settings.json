{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "mcp__linear-server__get_issue",
      "mcp__linear-server__list_issues",
      "mcp__linear-server__get_project",
      "mcp__linear-server__list_projects",
      "mcp__linear-server__get_team",
      "mcp__linear-server__list_teams",
      "mcp__linear-server__get_user",
      "mcp__linear-server__list_users",
      "mcp__linear-server__list_comments",
      "mcp__linear-server__list_issue_statuses",
      "mcp__linear-server__get_issue_status",
      "mcp__linear-server__get_document",
      "mcp__linear-server__list_documents",
      "mcp__linear-server__get_milestone",
      "mcp__linear-server__list_milestones",
      "mcp__linear-server__list_cycles",
      "mcp__linear-server__list_issue_labels",
      "mcp__linear-server__list_project_labels",
      "mcp__linear-server__get_attachment",
      "mcp__linear-server__search_documentation",
      "mcp__linear-server__extract_images"
    ]
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'NAME=$(jq -r .name); DIR=\"$CLAUDE_PROJECT_DIR/.claude/worktrees/$NAME\"; git worktree add \"$DIR\" -b \"worktree-$NAME\" origin/rv1 >&2 && echo \"$DIR\"'"
          }
        ]
      }
    ]
  },
  "marketplaces": [
    {
      "name": "caveman",
      "source": "https://github.com/JuliusBrussee/caveman"
    }
  ],
  "plugins": [
    "caveman@caveman"
  ],
  "plugin_config": {
    "caveman": {
      "autoActivate": true,
      "defaultMode": "full" 
    }
  }
}